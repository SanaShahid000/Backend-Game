{
  "info": {
    "name": "Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "fileName", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/signup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@example.com\",\n  \"username\": \"user1\",\n  \"password\": \"password123\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/signup"
          }
        },
        {
          "name": "POST /auth/verify-email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@example.com\",\n  \"code\": \"123456\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/verify-email"
          }
        },
        {
          "name": "POST /auth/resend-code",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@example.com\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/resend-code"
          }
        },
        {
          "name": "POST /auth/login (sets token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.accessToken) {",
                  "    pm.collectionVariables.set('token', json.accessToken);",
                  "  }",
                  "  if (json && json.profile && json.profile.userId) {",
                  "    pm.collectionVariables.set('userId', json.profile.userId);",
                  "  }",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@example.com\",\n  \"password\": \"password123\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Upload (JWT required)",
      "item": [
        {
          "name": "POST /upload/single",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] },
                { "key": "folder", "type": "text", "value": "docs" }
              ]
            },
            "url": "{{baseUrl}}/upload/single"
          }
        },
        {
          "name": "POST /upload/multiple",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "files", "type": "file", "src": [] },
                { "key": "folder", "type": "text", "value": "invoices" }
              ]
            },
            "url": "{{baseUrl}}/upload/multiple"
          }
        },
        {
          "name": "POST /upload/image",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image", "type": "file", "src": [] }
              ]
            },
            "url": "{{baseUrl}}/upload/image"
          }
        },
        {
          "name": "DELETE /upload/:fileName",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/upload/{{fileName}}"
          }
        }
      ]
    }
    ,
    {
      "name": "Profile (JWT required)",
      "item": [
        {
          "name": "GET /profile/me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/profile/me"
          }
        },
        {
          "name": "GET /profile/:userId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/profile/{{userId}}"
          }
        },
        {
          "name": "PATCH /profile/me",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profilePicture\": \"\",\n  \"country\": \"Pakistan\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/profile/me"
          }
        }
        ,
        {
          "name": "PATCH /profile/me/country",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country\": \"Pakistan\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/profile/me/country"
          }
        },
        {
          "name": "GET /profile/me/presets",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/profile/me/presets"
          }
        },
        {
          "name": "POST /profile/me/presets",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"preset\": {\n    \"carPresetName\": \"My Awesome Car\",\n    \"color\": \"Blue\"\n  }\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/profile/me/presets"
          }
        },
        {
          "name": "DELETE /profile/me",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/profile/me"
          }
        }
      ]
    }
  ]
}
